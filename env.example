# ============================================================
#  복사해서 사용:  cp .env.example .env   (값 채운 뒤, .env 는 커밋 금지)
#  실시간 연동 점검:  python launch.py preflight   (또는 라이브_점검.bat)
# ============================================================

# ── 데이터 소스 ───────────────────────────────────────────
#  mock = 데모(샘플) 데이터 / live = 실시간 실데이터
#  실시간으로 보려면 live 로 바꾸고 아래 키들을 채우세요.
RECO_DATA_SOURCE=live

# ── 공개 호스팅 모드(법적 안전) ───────────────────────────
#  서버에 올려 다른 사람과 공유 + 광고할 때는 반드시 true 로 두세요.
#  true 면 KIS/KRX 시세 재배포 위험 요소를 모두 끕니다:
#    · 좌측 수급 스크리너 / 시세 / 거래대금 / 오실레이터 / 실시간 압력 / 지수 / 세부수급 비활성
#  남는 기능(법적으로 비교적 안전): DART 공시 · 뉴스(제목+링크) · 커뮤니티 · 종목 검색(이름)
#  false 면 본인 PC에서 본인 키로 전체 기능을 쓰는 개인용 모드입니다(공유·광고 금지).
RECO_PUBLIC_MODE=false

# ── 커뮤니티 운영자(모더레이션) ───────────────────────────
#  채팅·게시판 신고 처리, 게시물 숨김, 금지어 관리에 필요합니다.
#  아무 문자열이나 비밀로 정하세요(이 값을 아는 사람만 운영자 패널 사용 가능).
#  비우면 운영자 기능이 비활성됩니다.
RECO_ADMIN_TOKEN=

# ── 신고 자동 숨김 임계치 ─────────────────────────────────
#  서로 다른 신고자가 이 수 이상 신고하면 운영자 없이도 자동 숨김됩니다.
#  (운영자 부재 시간대에도 부적절 콘텐츠 노출을 막아 광고 정책 위반 위험 완화)
RECO_REPORT_AUTOHIDE=3

# ── SEO / PWA (선택) ──────────────────────────────────────
#  사이트 주소를 넣으면 sitemap.xml·robots.txt 에 반영됩니다(검색 노출용).
#  예: https://my-domain.com
RECO_SITE_URL=

# ── 광고: Google AdSense (선택) ───────────────────────────
#  AdSense 게시자 ID를 넣으면 상단 광고 자리에 애드센스가 표시됩니다.
#  (AdSense → 계정 → 설정 → 게시자 ID, 예: ca-pub-1234567890123456)
#  비우면 web/ad.txt 로 직접 배너를 넣는 수동 방식이 쓰입니다.
#  ★ 신청 전 legal/애드센스_금융광고_점검.txt 를 꼭 확인하세요(금융 콘텐츠 정책).
#  ★ ads.txt 를 도메인 루트에 배치하세요(web/ads.txt.template 참고).
RECO_ADSENSE_PUB=
RECO_ADSENSE_SLOT=

# ── 유니버스(관심종목) ────────────────────────────────────
#  라이브는 watchlist(관심종목) 모드를 권장합니다.
#  market(전종목)은 KIS 호출이 매우 많아 느리고 한도에 걸릴 수 있습니다.
RECO_UNIVERSE=market           # market=전체 시장 종목선정, watchlist=관심종목만
#  관심종목: 쉼표 구분. 비우면 watchlist.txt 파일을 읽음.
RECO_WATCHLIST=005930,000660,373220,207940,005380,000270,068270,035420,247540,196170
RECO_TOP_N=30
RECO_SCAN_LIMIT=2000           # 종목선정 채점 대상(거래대금 상위 N). 전체 시장이면 크게.
RECO_MAX_SYMBOLS=4000          # 적재할 최대 종목수(전체 시장 안전상한)

# ── KIS (한국투자증권) — 실시간 시세·일봉·수급·현재가 ──────
#  apiportal.koreainvestment.com 에서 발급 (모의투자 계좌면 KIS_PAPER=true)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_PAPER=true                 # 모의투자 도메인(true) / 실전(false)
# 보유종목 조회용 계좌번호(선택, 읽기 전용). "12345678-01" 형식.
KIS_ACCOUNT=

# ── DART (전자공시) — 재무 + 실시간 공시 + 종목명 ─────────
#  opendart.fss.or.kr 무료 발급. 키 넣고 preflight 실행하면 corp_code 맵 자동 생성.
DART_API_KEY=

# ── 네이버 뉴스 검색 — 실시간 언론 기사(선택) ─────────────
#  developers.naver.com 무료 발급. 없어도 화면의 '네이버 검색' 버튼은 동작.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── LLM (선택 — 없으면 오프라인 폴백) ─────────────────────
ANTHROPIC_API_KEY=
RECO_LLM_MODEL=claude-sonnet-4-6

# ── 기타 ──────────────────────────────────────────────────
RECO_ALLOW_UNCALIBRATED=true   # 규칙기반(미보정) 가중치 사용 허용
RECO_DB=data/reco.sqlite3

# 네이버 카페 바로가기(선택) — 본인 카페 주소를 넣으면 상단에 '카페' 버튼이 생깁니다.
RECO_CAFE_URL=
RECO_CAFE_NAME=내 카페
# 구글 뉴스 RSS 추가 수집(네이버 보완, 키 불필요). 끄려면 0.
RECO_GOOGLE_NEWS=1

# ── 정부정책 피드(공공누리) ──────────────────────────────
#  정책브리핑(korea.kr)·부처 보도자료 RSS. 키 불필요. 1=켜기(기본), 0=끄기.
#  제목+링크+출처만 표시(본문 미복제). RSS 주소는 app/providers/policy_news.py 의 SOURCES 에서 조정.
RECO_POLICY_NEWS=1

# ── 공공데이터포털(data.go.kr) — 공시일정·보호예수·기업정보 (선택) ──
#  data.go.kr 무료 발급. 공시정보/주식발행정보/기업기본정보 등 금융 공공데이터.
#  ⚠ 데이터별 공공누리 유형이 다름. 광고(상업) 운영 시 각 데이터 약관을 꼭 확인.
DATA_GO_KR_KEY=

# ── 환율 (한국수출입은행, 선택) ──
#  oapi.koreaexim.go.kr 무료 발급. 원/달러·엔·유로 등 환율 고시(안전한 공공 시세).
EXIM_API_KEY=

# ── (선택) 기업이벤트 엔드포인트 직접 지정 ──
#  공공데이터포털 Swagger 명세에서 확인한 '정확한 요청주소'를 넣으면 기본값을 덮어씁니다.
#  운영자 패널의 '기업이벤트 API 점검'에서 실패가 나오면 아래에 정확한 주소를 넣으세요.
# RECO_CORP_EP_DIVIDEND=https://apis.data.go.kr/1160100/service/.../getDividendInfo
# RECO_CORP_EP_RIGHTS=
# RECO_CORP_EP_TREASURY=
# RECO_CORP_EP_LOCKUP=
# RECO_CORP_EP_CORP=
# RECO_CORP_EP_FINANCE=
# RECO_CORP_EP_DIVDETAIL=
# RECO_CORP_EP_RIGHTSCHED=
